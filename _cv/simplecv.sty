\ProvidesPackage{simplecv}[2026/05/07 Site-matched Simple-CV variant]

% Based on Simple-CV by Doruk Cetin:
% https://github.com/dcetin/Simple-CV
% Original template is available under the MIT license.

\RequirePackage[margin=0.75in]{geometry}
\RequirePackage[T1]{fontenc}
\RequirePackage{lmodern}
\RequirePackage{xcolor}
\RequirePackage{hyperref}
\RequirePackage{titlesec}
\RequirePackage{enumitem}
\RequirePackage{fancyhdr}
\RequirePackage{lastpage}
\RequirePackage{tabularx}

\definecolor{sitegreen}{HTML}{003F30}
\definecolor{sitepurple}{HTML}{B9A0FF}
\definecolor{sitetext}{HTML}{1A1A1A}
\definecolor{sitedetail}{HTML}{666666}

\providecommand{\theme}{sitegreen}

\colorlet{color-title}{\theme}
\colorlet{color-link}{sitepurple}
\colorlet{color-text}{sitetext}
\colorlet{color-detail}{sitedetail}

\hypersetup{
  colorlinks=true,
  urlcolor=color-link,
  linkcolor=color-title
}

\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}
\fancyfoot[R]{\small\textcolor{color-detail}{Page \thepage\ of \pageref{LastPage}}}

\raggedbottom
\raggedright
\setlength{\parindent}{0pt}
\setlength{\parskip}{4pt}
\setlength{\tabcolsep}{0pt}
\urlstyle{same}
\AtBeginDocument{\color{color-text}}

\titleformat{\section}
  {\scshape\raggedright\Large\color{color-title}}
  {}
  {0em}
  {}
  [\color{color-title}\titlerule\vspace{-4pt}]

\titlespacing*{\section}{0pt}{18pt}{8pt}

\setlist[itemize]{
  leftmargin=*,
  itemsep=2pt,
  topsep=2pt,
  parsep=0pt
}

\newcommand{\link}[2]{\href{#1}{#2}}
\newcommand{\email}[1]{\href{mailto:#1}{#1}}
\newcommand{\website}[1]{\href{https://#1/}{#1}}

\newcommand{\headinginline}[2]{
  \begin{minipage}[t]{0.58\textwidth}
    {\Huge\bfseries\textcolor{color-title}{#1}}\\[3pt]
    {\Large #2}
  \end{minipage}
  \hfill
}

\newcommand{\headingcontact}[1]{
  \begin{minipage}[t]{0.38\textwidth}
    \begin{flushright}
      \small #1
    \end{flushright}
  \end{minipage}
}

\newcommand{\outerlist}[1]{\begin{itemize}#1\end{itemize}}

\newcommand{\entrymid}[3]{
  \item
  \begin{tabularx}{\linewidth}[t]{@{}X r@{}}
    \textbf{#1} & \textcolor{color-detail}{#2} \\
  \end{tabularx}
  \small #3
}

\newcommand{\entrybigwithbody}[5]{
  \item
  \begin{tabularx}{\linewidth}[t]{@{}X r@{}}
    \textbf{#1} & \textcolor{color-detail}{#2} \\
    \small #3 & \small\textcolor{color-detail}{#4} \\
  \end{tabularx}
  \par\smallskip{\small\color{color-detail}#5}
}

\newcommand{\cvheading}[3]{
  \headinginline{#1}{#2}
  \headingcontact{#3}
}

\newcommand{\cvsection}[1]{\section{#1}}
\newcommand{\cvtext}[1]{\small #1}
\newcommand{\cvparagraph}[1]{\par\smallskip #1}

\newcommand{\cvjob}[5]{
  \outerlist{
    \entrybigwithbody{#1}{#2}{#3}{#4}{#5}
  }
}

\newcommand{\cveducation}{\cvjob}

\newcommand{\cvtalk}[3]{
  \outerlist{
    \entrymid{#1}{#2}{#3}
  }
}
